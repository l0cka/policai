# AI classification for the collector (optional — pick one).
# Without a key, detection falls back to keyword heuristics and every
# detection is labelled "Needs review".
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Optional model override for whichever provider is configured.
# Defaults: claude-opus-4-8 (Anthropic) / openrouter/auto (OpenRouter).
AI_MODEL=

# Local-only MCP source-ingest writes
POLICAI_MCP_ADMIN_TOKEN=
